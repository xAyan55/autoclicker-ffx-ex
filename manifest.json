{
  "manifest_version": 3,
  "name": "Auto Clicker",
  "version": "1.0",
  "description": "Automatically click on a selected area after a custom timer (Firefox Edition).",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Clicker"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "toggle-auto-clicker": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Toggle Auto Clicker Start/Stop"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "autoclicker-fx@example.com",
      "strict_min_version": "109.0"
    }
  }
}
